# ── Application ──────────────────────────────────────────────────────────────
# Режим запуска: пока поддерживается только "web"
WORK_TYPE=web

# ── Internal database (хранит конфиги, задания, маппинги схем) ────────────────
# Формат: postgresql+psycopg://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/db_m

# ── Flask ─────────────────────────────────────────────────────────────────────
# ВАЖНО: замените на случайную строку в production
SECRET_KEY=dev-secret-key

# 1 = включить отладочный режим Flask (только для разработки)
FLASK_DEBUG=0

FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=5000

# 1 = выводить все SQL-запросы в консоль (удобно при отладке)
SQLALCHEMY_ECHO=0

# ── Мониторинг доступности (плашки в шапке) ──────────────────────────────────
# Интервал фоновой проверки доступности источника, приёмника, Kafka и Kafka Connect
# Значение в секундах, по умолчанию 60
STATUS_CHECK_INTERVAL_SECONDS=60

# ── Очистка завершённых заданий ───────────────────────────────────────────────
# Интервал фонового удаления успешных заданий (status=success)
# Значение в секундах, по умолчанию 60
JOB_CLEANUP_INTERVAL_SECONDS=60

# ── Профили подключений (хранятся в БД через /api/configs) ───────────────────
#
# После запуска приложения создайте профили через API:
#
# Source / Target DB (config_type: "source_db" или "target_db"):
#   settings.database_url  — строка подключения к Oracle через oracledb
#     пример: oracle+oracledb://user:pass@host:1521/service_name
#
# Kafka (config_type: "kafka"):
#   settings.bootstrap_servers — список брокеров через запятую
#     пример: kafka1:9092,kafka2:9092
#
# Kafka Connect (config_type: "kafka_connect"):
#   settings.connect_url — URL кластера Kafka Connect
#     пример: http://kafka-connect:8083
